# ─── RTKdata Integrity Engine — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────
DB_PATH=./data/integrity.db

# ── Server ────────────────────────────────────────────────────────────────
PORT=10000

# ── Authentication (REQUIRED — default-deny if not set) ───────────────────
AUTH_USER=rtkdata
AUTH_PASS=
API_KEY=

# ── GEODNET Integration ──────────────────────────────────────────────────
GEODNET_APP_ID=
GEODNET_APP_KEY=

# ── ONOCOY Integration ──────────────────────────────────────────────────
ONOCOY_USER=
ONOCOY_PASS=

# ── GEODNET PPK (optional — deep quality analysis) ──────────────────────
PPK_USER=
PPK_PASS=

# ── RTKBI Historical Data (optional) ────────────────────────────────────
RTKBI_URL=
RTKBI_API_KEY=

# ── Caster Deployment (SSH to Alberding instances) ──────────────────────
# EU Instance
CASTER_EU_HOST=
CASTER_EU_PORT=22
CASTER_EU_USER=

# US Instance
CASTER_US_HOST=
CASTER_US_PORT=22
CASTER_US_USER=

# APAC Instance
CASTER_AP_HOST=
CASTER_AP_PORT=22
CASTER_AP_USER=

# Or provide all instances as JSON:
# CASTER_INSTANCES=[{"id":"eu","host":"...","port":22,"user":"...","enabled":true}]

# ── Alerting (optional) ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# ── Feature Flags ──────────────────────────────────────────────────────
FENCE_AUTO_DEPLOY=false
FENCE_AUTO_PUSH=false
